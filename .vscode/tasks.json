{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Holefeeder on iPhone",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/Holefeeder.Ui.Maui/Holefeeder.Ui.Maui.csproj",
                "-t:Run",
                "-f",
                "net8.0-ios",
                "-p:_DeviceName=:v2:udid=${env:IPHONE_UDID}",
                "-p:RuntimeIdentifier=ios-arm64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build and run the .NET MAUI application on a physical iPhone."
        },
        {
            "label": "Run Holefeeder on Mac",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/Holefeeder.Ui.Maui/Holefeeder.Ui.Maui.csproj",
                "-t:Run",
                "-f",
                "net8.0-maccatalyst",
                "-p:_DeviceName=:v2:udid=${env:MACBOOK_UDID}",
                "-p:RuntimeIdentifier=maccatalyst-arm64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build and run the .NET MAUI application on a physical iPhone."
        },
        {
            "label": "Build Holefeeder for iPhone",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/Holefeeder.Ui.Maui/Holefeeder.Ui.Maui.csproj",
                "-f",
                "net8.0-ios",
                "-p:RuntimeIdentifier=ios-arm64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "detail": "Build and run the .NET MAUI application on a physical iPhone."
        },
        {
            "type": "dotnet-meteor.task",
            // "target": "build",
            "args": [],
            "problemMatcher": [],
            "label": "dotnet-meteor: build",
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DrifterApps.Holefeeder.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/DrifterApps.Holefeeder.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "${workspaceFolder}/DrifterApps.Holefeeder.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "holefeeder test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "--settings",
                ".runsettings",
                "--filter",
                "FullyQualifiedName!~Holefeeder.Tests.Common"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "holefeeder code coverage report",
            "command": "dotnet",
            "type": "process",
            "args": [
                "reportgenerator",
                "-reports:${workspaceFolder}/coverage/coverage.cobertura.xml",
                "-targetdir:${workspaceFolder}/coverage",
                "-filefilters:-*.g.cs"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "holefeeder code coverage",
            "dependsOn": [
                "holefeeder test",
                "holefeeder code coverage report"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "holefeeder staging",
            "command": "docker",
            "type": "process",
            "args": [
                "compose",
                "-f",
                "${workspaceFolder}/docker-compose.yaml",
                "-f",
                "${workspaceFolder}/docker-compose.Staging.yaml",
                "up",
                "-d",
                "--build"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
